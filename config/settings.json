{
  "version": "3.4 Balanced UI Fix",
  "site_name": "星の館 全天カメラ AIエージェント",
  "camera": {
    "width": 3072,
    "height": 3072,
    "night_mode": "auto",
    "night_exposure_us": 1800000,
    "night_gain": 20,
    "photo_timeout_ms_day": 1000,
    "photo_timeout_ms_night": 2500,
    "video_time_ms": 10000
  },
  "bme280": {
    "enabled": true,
    "bus": "auto",
    "address": "auto"
  },
  "wind": {
    "enabled": true,
    "gpio_pin": 17,
    "pulses_per_rotation": 3,
    "cup_radius_m": 0.04,
    "calibration_factor": 1.0,
    "sample_seconds": 2.0
  },
  "rain": {
    "enabled": false,
    "gpio_pin": 27,
    "active_low": true
  }
}