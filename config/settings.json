{
  "version": "2.8 Round True Fit",
  "site_name": "星の館 全天カメラ AIエージェント",
  "camera": {
    "width": 3072,
    "height": 3072,
    "photo_timeout_ms": 1000,
    "video_time_ms": 10000,
