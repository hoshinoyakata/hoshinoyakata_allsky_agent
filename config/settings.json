{
  "version": "4.6 Startup Fix",
  "site_name": "星の館 全天カメラAIエージェント",
  "camera": {
    "width": 3072,
    "height": 3072,
    "night_mode": "auto",
    "night_exposure_us": 1800000,
    "night_gain": 20,
    "photo_timeout_ms_day": 1000,
    "photo_timeout_ms_night": 2500,
    "live_poll_seconds": 2,
    "auto_capture_enabled": true,
    "live_capture_seconds": 5,
    "keep_images": 1200
  },
  "bme280": {
    "enabled": true,
    "bus": 1,
    "address": "auto",
    "altitude_m": 108,
    "pressure_unit_auto_fix": true,
    "pressure_offset_hpa": 0.0
  },
  "wind": {
    "enabled": true,
    "gpio_pin": 17,
    "pulses_per_rotation": 3,
    "cup_radius_m": 0.04,
    "calibration_factor": 1.0,
    "sample_seconds": 2.0
  },
  "rain": {
    "enabled": false,
    "gpio_pin": 27,
    "active_low": true
  },
  "ui": {
    "thumb_label": "actual_time",
    "fullscreen_scale": "96vh",
    "image_scale": 1.0
  }
}