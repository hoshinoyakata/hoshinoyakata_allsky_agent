[Unit]
Description=Hoshinoyakata Allsky AI Agent
After=network.target

[Service]
WorkingDirectory=/home/pi/hoshinoyakata_allsky_agent
ExecStart=/home/pi/hoshinoyakata_allsky_agent/venv/bin/python /home/pi/hoshinoyakata_allsky_agent/web/app.py
Restart=always
RestartSec=5
User=pi

[Install]
WantedBy=multi-user.target
